{
    "name": "@smooai/fetch",
    "version": "3.3.9",
    "description": "A powerful fetch client library built on top of the native `fetch` API, designed for both Node.js and browser environments. Features built-in support for retries, timeouts, rate limiting, circuit breaking, and Standard Schema validation.",
    "homepage": "https://github.com/SmooAI/fetch#readme",
    "bugs": {
        "url": "https://github.com/SmooAI/fetch/issues"
    },
    "license": "MIT",
    "author": {
        "name": "SmooAI",
        "email": "brent@smooai.com",
        "url": "https://smooai.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/SmooAI/fetch.git"
    },
    "files": [
        "dist/**"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "browser": {
                "import": {
                    "types": "./dist/browser/index.d.mts",
                    "default": "./dist/browser/index.mjs"
                },
                "require": {
                    "types": "./dist/browser/index.d.cts",
                    "default": "./dist/browser/index.cjs"
                },
                "default": "./dist/browser/index.cjs"
            },
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            },
            "default": "./dist/index.cjs"
        },
        "./browser": {
            "import": {
                "types": "./dist/browser/index.d.mts",
                "default": "./dist/browser/index.mjs"
            },
            "require": {
                "types": "./dist/browser/index.d.cts",
                "default": "./dist/browser/index.cjs"
            },
            "default": "./dist/browser/index.cjs"
        },
        "./browser/*": {
            "import": {
                "types": "./dist/browser/*.d.mts",
                "default": "./dist/browser/*.mjs"
            },
            "require": {
                "types": "./dist/browser/*.d.cts",
                "default": "./dist/browser/*.cjs"
            }
        },
        "./*": {
            "import": {
                "types": "./dist/*.d.mts",
                "default": "./dist/*.mjs"
            },
            "require": {
                "types": "./dist/*.d.cts",
                "default": "./dist/*.cjs"
            }
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "aibranch": "pnpm generate-git-branch",
        "build": "pnpm tsdown && pnpm run python:build && pnpm run rust:build && pnpm run go:build && pnpm run dotnet:build",
        "check-all": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test && pnpm run python:typecheck && pnpm run python:lint && pnpm run python:format:check && pnpm run rust:fmt:check && pnpm run rust:lint && pnpm run rust:test && pnpm run go:fmt:check && pnpm run go:lint && pnpm run go:test && pnpm run dotnet:format:check && pnpm run dotnet:test && pnpm run build",
        "ci:publish": "pnpm build && pnpm changeset publish && pnpm run version:sync",
        "format": "oxfmt --write . && pnpm run python:format && pnpm run rust:fmt && pnpm run go:fmt && pnpm run dotnet:format",
        "lint": "oxlint . && pnpm run python:lint && pnpm run rust:lint && pnpm run go:lint",
        "lint:fix": "oxlint --fix .",
        "pre-commit-check": "(zsh .husky/pre-commit)",
        "prepare": "husky",
        "test": "vitest run --passWithNoTests && pnpm python:test && pnpm rust:test && pnpm go:test && pnpm dotnet:test",
        "typecheck": "tsc --noEmit --skipLibCheck && pnpm run python:typecheck && pnpm run rust:check",
        "watch": "tsdown --watch",
        "format:check": "oxfmt --check .",
        "python:build": "(cd python && uv run poe build)",
        "python:format": "(cd python && uv run poe format)",
        "python:format:check": "(cd python && uv run poe format:check)",
        "python:install-dev": "(cd python && uv run poe install-dev)",
        "python:lint": "(cd python && uv run poe lint)",
        "python:lint:fix": "(cd python && uv run poe lint:fix)",
        "python:test": "(cd python && uv run poe test)",
        "python:typecheck": "(cd python && uv run poe typecheck)",
        "rust:build": "(cd rust/fetch && cargo build --release)",
        "rust:check": "(cd rust/fetch && cargo check --all-targets)",
        "rust:fmt": "(cd rust/fetch && cargo fmt)",
        "rust:fmt:check": "(cd rust/fetch && cargo fmt --all -- --check)",
        "rust:lint": "(cd rust/fetch && cargo clippy --all-targets -- -D warnings)",
        "rust:test": "(cd rust/fetch && cargo test)",
        "go:build": "(cd go/fetch && go build ./...)",
        "go:fmt": "(cd go/fetch && gofmt -w .)",
        "go:fmt:check": "(cd go/fetch && test -z \"$(gofmt -l .)\")",
        "go:lint": "(cd go/fetch && go vet ./...)",
        "go:test": "(cd go/fetch && go test -v ./...)",
        "dotnet:build": "(cd dotnet && dotnet build SmooAI.Fetch.sln -c Release --nologo)",
        "dotnet:test": "(cd dotnet && dotnet test SmooAI.Fetch.sln -c Release --nologo)",
        "dotnet:pack": "(cd dotnet && dotnet pack SmooAI.Fetch/SmooAI.Fetch.csproj -c Release --nologo -o ./artifacts)",
        "dotnet:format": "(cd dotnet && dotnet format SmooAI.Fetch.sln)",
        "dotnet:format:check": "(cd dotnet && dotnet format SmooAI.Fetch.sln --verify-no-changes)",
        "version:sync": "node scripts/sync-versions.mjs"
    },
    "dependencies": {
        "@faker-js/faker": "^9.6.0",
        "@smooai/logger": "^4.1.4",
        "@smooai/utils": "^1.3.3",
        "@standard-schema/spec": "^1.0.0",
        "@standard-schema/utils": "^0.3.0",
        "lodash.merge": "^4.6.2",
        "mollitia": "^0.1.1"
    },
    "devDependencies": {
        "@changesets/cli": "^2.28.1",
        "@rollup/plugin-alias": "latest",
        "@smooai/config-typescript": "^1.0.16",
        "@types/lodash.merge": "^4.6.9",
        "@types/node": "^22.13.10",
        "husky": "^9.1.7",
        "msw": "^2.7.3",
        "oxfmt": "^0.28.0",
        "oxlint": "^0.16.0",
        "tsdown": "latest",
        "typescript": "^5.8.2",
        "unrun": "latest",
        "vite": "^6.2.4",
        "vite-node": "^3.1.1",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.1.1",
        "zod": "^4.1.5"
    },
    "packageManager": "pnpm@10.6.1+sha512.40ee09af407fa9fbb5fbfb8e1cb40fbb74c0af0c3e10e9224d7b53c7658528615b2c92450e74cfad91e3a2dcafe3ce4050d80bda71d757756d2ce2b66213e9a3"
}
