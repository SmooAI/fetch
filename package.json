{
    "name": "@smooai/fetch",
    "version": "2.1.1",
    "description": "A powerful fetch client library built on top of the native `fetch` API, designed for both Node.js and browser environments. Features built-in support for retries, timeouts, rate limiting, circuit breaking, and Standard Schema validation.",
    "homepage": "https://github.com/SmooAI/fetch#readme",
    "bugs": {
        "url": "https://github.com/SmooAI/fetch/issues"
    },
    "license": "MIT",
    "author": {
        "name": "SmooAI",
        "email": "brent@smooai.com",
        "url": "https://smooai.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/SmooAI/fetch.git"
    },
    "files": [
        "dist/**"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.mjs",
            "require": "./dist/*.js"
        },
        "./browser/*": {
            "types": "./dist/browser/*.d.ts",
            "import": "./dist/browser/*.mjs",
            "require": "./dist/browser/*.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "aibranch": "pnpm generate-git-branch",
        "build": "pnpm tsup",
        "check-all": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build",
        "ci:publish": "pnpm build && pnpm changeset publish",
        "format": "oxfmt --write .",
        "lint": "oxlint .",
        "lint:fix": "oxlint --fix .",
        "pre-commit-check": "(zsh .husky/pre-commit)",
        "prepare": "husky",
        "test": "vitest run --passWithNoTests",
        "typecheck": "tsc --noEmit --skipLibCheck",
        "watch": "tsup --watch",
        "format:check": "oxfmt --check ."
    },
    "dependencies": {
        "@faker-js/faker": "^9.6.0",
        "@smooai/logger": "^3.1.2",
        "@smooai/utils": "^1.3.2",
        "@standard-schema/spec": "^1.0.0",
        "@standard-schema/utils": "^0.3.0",
        "lodash.merge": "^4.6.2",
        "mollitia": "^0.1.1"
    },
    "devDependencies": {
        "@changesets/cli": "^2.28.1",
        "@smooai/config-typescript": "^1.0.16",
        "@types/lodash.merge": "^4.6.9",
        "@types/node": "^22.13.10",
        "esbuild-plugin-alias": "^0.2.1",
        "husky": "^9.1.7",
        "lint-staged": "^15.4.3",
        "msw": "^2.7.3",
        "oxfmt": "^0.28.0",
        "oxlint": "^0.16.0",
        "tsup": "^8.4.0",
        "vite": "^6.2.4",
        "vite-node": "^3.1.1",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.1.1",
        "zod": "^4.1.5"
    },
    "packageManager": "pnpm@10.6.1+sha512.40ee09af407fa9fbb5fbfb8e1cb40fbb74c0af0c3e10e9224d7b53c7658528615b2c92450e74cfad91e3a2dcafe3ce4050d80bda71d757756d2ce2b66213e9a3"
}
